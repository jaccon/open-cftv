{
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.formatOnSave": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "javascript.format.semicolons": "insert",
  "files.associations": {
    "*.css": "css",
    "*.html": "html",
    "*.js": "javascript"
  },
  "search.exclude": {
    "dist": true,
    "node_modules": true,
    "build": true
  }
}
